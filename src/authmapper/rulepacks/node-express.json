{
  "name": "node-express",
  "language": "javascript",
  "framework": "express",
  "file_globs": ["**/*.js", "**/*.mjs", "**/*.cjs", "**/*.ts"],
  "endpoint_model": "route",
  "endpoint_patterns": [
    {
      "id": "express-route",
      "regex": "\\b(?:app|router|api)\\.(get|post|put|delete|patch|all)\\s*\\(\\s*['\"`]([^'\"`]+)['\"`]",
      "capture": { "method": 1, "path": 2 }
    }
  ],
  "auth_signals": [
    {
      "id": "inline-auth-middleware",
      "regex": "\\b(requireAuth|isAuthenticated|ensureAuthenticated|authenticate|authMiddleware|verifyToken|verifyJwt|checkAuth|passport\\.authenticate|requireLogin|adminOnly|authorize)\\b",
      "scope": "same_line"
    },
    {
      "id": "router-level-guard",
      "regex": "\\b(?:app|router)\\.use\\s*\\(\\s*[^)]*\\b(auth|authenticate|requireAuth|passport|jwt)\\b",
      "scope": "file"
    }
  ]
}
