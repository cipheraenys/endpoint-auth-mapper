{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://authmap.dev/schemas/evidence-policy-1.0.json",
  "title": "Authmap evidence gate policy 1.0",
  "type": "object",
  "properties": {
    "$schema": { "const": "https://authmap.dev/schemas/evidence-policy-1.0.json" },
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$" },
    "fail_on_unguarded": { "type": "boolean" },
    "fail_on_unresolved": { "type": "boolean" },
    "fail_on_incomplete_coverage": { "type": "boolean" },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$" },
          "adapter_id": { "type": "string", "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$" },
          "adapter_version": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
          },
          "capability": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "minimum_maturity": { "enum": ["experimental", "verified"] }
        },
        "required": ["id", "adapter_id", "adapter_version", "capability", "minimum_maturity"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "$schema",
    "schema_version",
    "id",
    "fail_on_unguarded",
    "fail_on_unresolved",
    "fail_on_incomplete_coverage",
    "requirements"
  ],
  "additionalProperties": false
}
